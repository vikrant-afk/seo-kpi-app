# ---- Local development (.env). On Streamlit Cloud use .streamlit/secrets.toml instead ----

# Google service account key file (GA4 + GA Admin + Search Console + Sheets)
GOOGLE_APPLICATION_CREDENTIALS=./service_account.json

# PageSpeed Insights
PAGESPEED_API_KEY=

# Ahrefs API v3 (DR + Referring Domains)
AHREFS_API_TOKEN=

# DataForSEO (Spam Score, Referring Domains fallback, optional DA proxy)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# DA (Moz Domain Authority) source: none = blank (Moz-only), dataforseo = use DFS rank as proxy
DA_SOURCE=none

# Google Sheets output — master workbook id (optional). Blank = new sheet each run.
OUTPUT_SHEET_ID=

# Custom-prompt LLM (optional): gemini | anthropic | none
LLM_PROVIDER=none
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
